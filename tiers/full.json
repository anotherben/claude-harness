{
  "name": "Full",
  "description": "Standard + context injection, cortex-engine, skills-index, cortex-memory, prompt refinement.",
  "extends": "standard",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          { "hook": "suggest-cortex.sh", "timeout": 5 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "hook": "suggest-skill.sh", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "hook": "cortex-reindex.sh", "timeout": 5 }
        ]
      },
      {
        "hooks": [
          { "hook": "context-fade.sh", "timeout": 5 }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          { "hook": "ensure-environment.sh", "timeout": 30 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "hook": "refine-prompt.sh", "timeout": 5 }
        ]
      }
    ],
    "PostCompact": [
      {
        "hooks": [
          { "hook": "post-compact-handover.sh", "timeout": 5 }
        ]
      }
    ]
  },
  "skills_add": [
    "conductor-resume"
  ],
  "templates_required": []
}
